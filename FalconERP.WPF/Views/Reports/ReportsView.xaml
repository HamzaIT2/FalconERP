<UserControl x:Class="FalconERP.WPF.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="التقارير"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <UniformGrid Grid.Row="1"
                     Columns="2"
                     Rows="3">

            <Button Content="📈 تقرير المبيعات"
                    Height="100"
                    Margin="10"
                    FontSize="18"
                    Click="SalesReport_Click"/>

            <Button Content="🛒 تقرير المشتريات"
                    Height="100"
                    Margin="10"
                    FontSize="18"
                    Click="PurchaseReport_Click"/>

            <Button Content="📦 تقرير المخزون"
                    Height="100"
                    Margin="10"
                    FontSize="18"
                     Click="InventoryReport_Click"/>

            <Button Content="👥 تقرير العملاء"
                    Height="100"
                    Margin="10"
                    FontSize="18"
                    Click="CustomerReport_Click"/>

            <Button Content="🏢 تقرير الموردين"
                    Height="100"
                    Margin="10"
                    FontSize="18"
                    Click="SupplierReport_Click"/>

        </UniformGrid>

    </Grid>

</UserControl>