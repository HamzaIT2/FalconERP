<UserControl x:Class="FalconERP.WPF.Views.Reports.SalesReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- عنوان الصفحة -->

        <TextBlock Text="تقرير المبيعات"
                   FontSize="28"
                   FontWeight="Bold"/>

        <!-- أدوات التقرير -->

        <Border Grid.Row="1"
                Margin="0,20,0,10"
                Padding="15"
                CornerRadius="8"
                BorderBrush="#D6D6D6"
                BorderThickness="1">

            <WrapPanel VerticalAlignment="Center">

                <TextBlock Text="من"
                           Margin="5"
                           VerticalAlignment="Center"/>

                <DatePicker Width="140"
                            Margin="5"
                            SelectedDate="{Binding FromDate}"/>

                <TextBlock Text="إلى"
                           Margin="10,5,5,5"
                           VerticalAlignment="Center"/>

                <DatePicker Width="140"
                            Margin="5"
                            SelectedDate="{Binding ToDate}"/>

                <TextBlock Text="العميل"
                           Margin="10,5,5,5"
                           VerticalAlignment="Center"/>

                <TextBox Width="180"
                         Margin="5"
                         Text="{Binding SearchText,
                                        UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="بحث"
                        Width="90"
                        Margin="10,5"
                        Command="{Binding FilterCommand}"/>

                <Button Content="Excel"
                        Width="90"
                        Margin="5"
                        Command="{Binding ExportExcelCommand}"/>

            </WrapPanel>

        </Border>

        <!-- الإحصائيات -->

        <UniformGrid Grid.Row="2"
                     Columns="3"
                     Margin="0,10">

            <Border Margin="5"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="إجمالي المبيعات"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding TotalSales}"
                               FontSize="24"/>

                </StackPanel>

            </Border>

            <Border Margin="5"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="إجمالي المدفوع"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding TotalPaid}"
                               FontSize="24"/>

                </StackPanel>

            </Border>

            <Border Margin="5"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="إجمالي المتبقي"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding TotalRemaining}"
                               FontSize="24"/>

                </StackPanel>

            </Border>

        </UniformGrid>

        <!-- الجدول -->

        <DataGrid Grid.Row="3"
                  Margin="0,15,0,0"
                  ItemsSource="{Binding Sales}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="رقم الفاتورة"
                                    Binding="{Binding Id}"
                                    Width="110"/>

                <DataGridTextColumn Header="التاريخ"
                                    Binding="{Binding SaleDate}"
                                    Width="170"/>

                <DataGridTextColumn Header="العميل"
                                    Binding="{Binding Customer.Name}"
                                    Width="220"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding TotalAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="المدفوع"
                                    Binding="{Binding PaidAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="المتبقي"
                                    Binding="{Binding RemainingAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="الملاحظات"
                                    Binding="{Binding Notes}"
                                    Width="250"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>