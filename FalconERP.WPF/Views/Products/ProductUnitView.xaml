<UserControl x:Class="FalconERP.WPF.Views.Products.ProductUnitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->

        <TextBlock Grid.Row="0"
                   Text="إدارة الوحدات والأسعار"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- الإدخال -->

        <WrapPanel Grid.Row="1"
                   Margin="0,0,0,20">

            <StackPanel Margin="5">

                <TextBlock Text="المنتج"/>

                <ComboBox Width="180"
                          Height="35"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="Name"/>

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="اسم الوحدة"/>

                <TextBox Width="120"
                         Height="35"
                         Text="{Binding UnitName}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="التحويل"/>

                <TextBox Width="100"
                         Height="35"
                         Text="{Binding ConversionFactor}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="شراء"/>

                <TextBox Width="120"
                         Height="35"
                         Text="{Binding PurchasePrice}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="جملة"/>

                <TextBox Width="120"
                         Height="35"
                         Text="{Binding WholesalePrice}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="مفرد"/>

                <TextBox Width="120"
                         Height="35"
                         Text="{Binding RetailPrice}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="باركود"/>

                <TextBox Width="140"
                         Height="35"
                         Text="{Binding Barcode}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="افتراضي"/>

                <CheckBox IsChecked="{Binding IsDefault}"
                          HorizontalAlignment="Center"/>

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text=" "/>

                <Button Content="إضافة"
                        Width="100"
                        Height="35"
                        Command="{Binding AddUnitCommand}" />

            </StackPanel>

        </WrapPanel>

        <!-- الجدول -->

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ProductUnits}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding Product.Name}"
                                    Width="180"/>

                <DataGridTextColumn Header="الوحدة"
                                    Binding="{Binding UnitName}"
                                    Width="120"/>

                <DataGridTextColumn Header="التحويل"
                                    Binding="{Binding ConversionFactor}"
                                    Width="100"/>

                <DataGridTextColumn Header="شراء"
                                    Binding="{Binding PurchasePrice}"
                                    Width="120"/>

                <DataGridTextColumn Header="جملة"
                                    Binding="{Binding WholesalePrice}"
                                    Width="120"/>

                <DataGridTextColumn Header="مفرد"
                                    Binding="{Binding RetailPrice}"
                                    Width="120"/>

                <DataGridTextColumn Header="باركود"
                                    Binding="{Binding Barcode}"
                                    Width="160"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>