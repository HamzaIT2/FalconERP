<UserControl x:Class="FalconERP.WPF.Views.Purchases.PurchaseHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <TextBlock Text="سجل المشتريات"
                   FontSize="26"
                   FontWeight="Bold"/>

        <DataGrid Grid.Row="1"
                  Margin="0,15"
                  ItemsSource="{Binding Purchases}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  >

            <DataGrid.Columns>

                <DataGridTextColumn Header="رقم الفاتورة"
                                    Binding="{Binding Id}"
                                    Width="100"/>

                <DataGridTextColumn Header="التاريخ"
                                    Binding="{Binding PurchaseDate}"
                                    Width="170"/>

                <DataGridTextColumn Header="المورد"
                                    Binding="{Binding Supplier.Name}"
                                    Width="220"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding TotalAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="المدفوع"
                                    Binding="{Binding PaidAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="المتبقي"
                                    Binding="{Binding RemainingAmount}"
                                    Width="120"/>

                <DataGridTextColumn Header="الملاحظات"
                                    Binding="{Binding Notes}"
                                    Width="250"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>