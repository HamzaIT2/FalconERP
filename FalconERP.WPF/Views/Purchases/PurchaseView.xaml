<UserControl x:Class="FalconERP.WPF.Views.Purchases.PurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="فاتورة شراء"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Border Grid.Row="1"
                Margin="0,15"
                Padding="15"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- المورد -->

                <StackPanel Margin="5">

                    <TextBlock Text="المورد"/>

                    <ComboBox
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier}"
                        DisplayMemberPath="Name"/>

                </StackPanel>

                <!-- المنتج -->

                <StackPanel Grid.Column="1"
                            Margin="5">

                    <TextBlock Text="المنتج"/>

                    <ComboBox
                        ItemsSource="{Binding Products}"
                        SelectedItem="{Binding SelectedProduct}"
                        DisplayMemberPath="Name"/>

                </StackPanel>

                <!-- الوحدة -->

                <StackPanel Grid.Column="2"
                            Margin="5">

                    <TextBlock Text="الوحدة"/>

                    <ComboBox
                        ItemsSource="{Binding ProductUnits}"
                        SelectedItem="{Binding SelectedUnit}"
                        DisplayMemberPath="UnitName"/>

                </StackPanel>

                <!-- الكمية -->

                <StackPanel Grid.Row="1"
                            Margin="5">

                    <TextBlock Text="الكمية"/>

                    <TextBox Text="{Binding Quantity}"/>

                </StackPanel>

                <!-- السعر -->

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="5">

                    <TextBlock Text="السعر"/>

                    <TextBox Text="{Binding Price}"/>

                </StackPanel>

                <!-- زر الإضافة -->

                <Button Grid.Row="1"
                        Grid.Column="2"
                        Content="إضافة"
                        Height="35"
                        Margin="5"
                        VerticalAlignment="Bottom"
                        Command="{Binding AddItemCommand}"/>

            </Grid>

        </Border>

        <DataGrid Grid.Row="2"
                  Margin="0,10"
                  ItemsSource="{Binding PurchaseItems}"
                  SelectedItem="{Binding SelectedPurchaseItem}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    Width="200"/>

                <DataGridTextColumn Header="الوحدة"
                                    Binding="{Binding UnitName}"
                                    Width="150"/>

                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity}"
                                    Width="120"/>

                <DataGridTextColumn Header="السعر"
                                    Binding="{Binding Price}"
                                    Width="120"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding Total}"
                                    Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

        <Border Grid.Row="3"
                Padding="10"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Text="الإجمالي"/>

                    <TextBlock Text="{Binding GrandTotal}"
                               FontSize="20"
                               FontWeight="Bold"/>

                </StackPanel>

                <StackPanel Grid.Column="1">

                    <TextBlock Text="المدفوع"/>

                    <TextBox Text="{Binding PaidAmount}"/>

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <TextBlock Text="المتبقي"/>

                    <TextBlock Text="{Binding RemainingAmount}"
                               FontSize="20"
                               FontWeight="Bold"/>

                </StackPanel>

                <Button Grid.Column="3"
                        Content="حذف العنصر"
                        Width="120"
                        Height="35"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,50"
                        Command="{Binding RemoveItemCommand}"/>

                <Button Grid.Column="3"
                        Content="حفظ الفاتورة"
                        Width="120"
                        Height="35"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Command="{Binding SaveInvoiceCommand}"/>

            </Grid>

        </Border>

    </Grid>

</UserControl>