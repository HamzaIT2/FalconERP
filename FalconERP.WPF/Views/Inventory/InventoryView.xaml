<UserControl x:Class="FalconERP.WPF.Views.Inventory.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->

        <TextBlock Grid.Row="0"
                   Text="إدارة المخزون"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- الإدخال -->

        <WrapPanel Grid.Row="1"
                   Margin="0,0,0,20">

            <StackPanel Margin="5">

                <TextBlock Text="المنتج"/>

                <ComboBox Width="180"
                          Height="35"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="Name"/>

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="الوحدة"/>

                <ComboBox Width="180"
                          Height="35"
                          ItemsSource="{Binding ProductUnits}"
                          SelectedItem="{Binding SelectedUnit}"
                          DisplayMemberPath="UnitName"/>

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="الكمية"/>

                <TextBox Width="120"
                         Height="35"
                         Text="{Binding Quantity}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="نوع الحركة"/>

                <ComboBox Width="120"
                          Height="35"
                          SelectedValue="{Binding TransactionType}"
                          SelectedValuePath="Content">

                    <ComboBoxItem Content="إدخال"/>
                    <ComboBoxItem Content="إخراج"/>

                </ComboBox>

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text="ملاحظات"/>

                <TextBox Width="250"
                         Height="35"
                         Text="{Binding Notes}" />

            </StackPanel>

            <StackPanel Margin="5">

                <TextBlock Text=" "/>

                <Button Content="حفظ الحركة"
                        Width="120"
                        Height="35"
                        Command="{Binding SaveTransactionCommand}" />

            </StackPanel>

        </WrapPanel>

        <!-- جدول الحركات -->

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Transactions}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding Product.Name}"
                                    Width="180"/>

                <DataGridTextColumn Header="الوحدة"
                                    Binding="{Binding ProductUnit.UnitName}"
                                    Width="150"/>

                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity}"
                                    Width="100"/>

                <DataGridTextColumn Header="نوع الحركة"
                                    Binding="{Binding TransactionType}"
                                    Width="120"/>

                <DataGridTextColumn Header="التاريخ"
                                    Binding="{Binding TransactionDate}"
                                    Width="180"/>

                <DataGridTextColumn Header="ملاحظات"
                                    Binding="{Binding Notes}"
                                    Width="250"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>