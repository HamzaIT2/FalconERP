<UserControl x:Class="FalconERP.WPF.Views.Category.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->

        <TextBlock Grid.Row="0"
                   Text="إدارة التصنيفات"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- إضافة تصنيف -->

        <StackPanel Grid.Row="1"
            Orientation="Horizontal"
            Margin="0,0,0,20">

            <TextBox Width="250"
             Height="35"
             Margin="0,0,10,0"
             Text="{Binding CategoryName,
                            UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="إضافة"
            Width="100"
            Height="35"
            Margin="0,0,10,0"
            Command="{Binding AddCategoryCommand}" />

            <Button Content="تعديل"
            Width="100"
            Height="35"
            Margin="0,0,10,0"
            Command="{Binding UpdateCategoryCommand}" />

            <Button Content="حذف"
            Width="100"
            Height="35"
            Command="{Binding DeleteCategoryCommand}" />

        </StackPanel>

        <!-- جدول التصنيفات -->

        <DataGrid Grid.Row="2"
          ItemsSource="{Binding Categories}"
          SelectedItem="{Binding SelectedCategory}"
          AutoGenerateColumns="False"
          IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="المعرف"
                                    Binding="{Binding Id}"
                                    Width="100"/>

                <DataGridTextColumn Header="اسم التصنيف"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridCheckBoxColumn Header="فعال"
                                        Binding="{Binding IsActive}"
                                        Width="100"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>