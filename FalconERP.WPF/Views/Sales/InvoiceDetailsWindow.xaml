<Window x:Class="FalconERP.WPF.Views.Sales.InvoiceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل الفاتورة"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner"
        
        >

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <TextBlock Text="تفاصيل الفاتورة"
                   FontSize="24"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1"
                    Margin="0,20">

            <TextBlock Text="{Binding Invoice.InvoiceNumber,StringFormat=رقم الفاتورة : {0}}"/>

            <TextBlock Text="{Binding Invoice.CustomerName,StringFormat=العميل : {0}}"/>

            <TextBlock Text="{Binding Invoice.SaleDate,StringFormat=التاريخ : {0:dd/MM/yyyy}}"/>

        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding ProductName}"/>

                <DataGridTextColumn Header="الوحدة"
                                    Binding="{Binding UnitName}"/>

                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity}"/>

                <DataGridTextColumn Header="السعر"
                                    Binding="{Binding Price}"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding Total}"/>

            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="3"
                    Margin="0,15">

            <TextBlock Text="{Binding Invoice.TotalAmount,StringFormat=الإجمالي : {0}}"/>

            <TextBlock Text="{Binding Invoice.PaidAmount,StringFormat=المدفوع : {0}}"/>

            <TextBlock Text="{Binding Invoice.RemainingAmount,StringFormat=المتبقي : {0}}"/>

        </StackPanel>

    </Grid>

</Window>