<UserControl x:Class="FalconERP.WPF.Views.Sales.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->

        <TextBlock Grid.Row="0"
                   Text="فاتورة مبيعات"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- بيانات الفاتورة -->

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <ComboBox Width="220"
                      Height="35"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      DisplayMemberPath="Name"/>





            <ComboBox Width="220"
                      Height="35"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      DisplayMemberPath="Name"/>

            <ComboBox Width="220"
                      Height="35"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding ProductUnits}"
                      SelectedItem="{Binding SelectedUnit}"
                      DisplayMemberPath="UnitName"/>

            <TextBox Width="120"
                     Height="35"
                     Margin="0,0,10,0"
                     Text="{Binding Quantity}"/>

            <TextBox Width="120"
                     Height="35"
                     Margin="0,0,10,0"
                     Text="{Binding Price}"/>

            <Button Content="إضافة للفاتورة"
                    Width="140"
                    Height="35"
                    Command="{Binding AddItemCommand}"/>

            <Button Content="حفظ الفاتورة"
                    Width="150"
                    Height="40"
                    Margin="10"
                    Command="{Binding SaveInvoiceCommand}" />
            
            <Button Content="حذف العنصر"
                    Width="150"
                    Height="40"
                    Margin="10"
                    Command="{Binding RemoveItemCommand}" />

        </StackPanel>

        <!-- عناصر الفاتورة -->

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding SaleItems}"
                  SelectedItem="{Binding SelectedSaleItem}"
                  AutoGenerateColumns="False">





            <DataGrid.Columns>

                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    Width="250"/>

                <DataGridTextColumn Header="الوحدة"
                                    Binding="{Binding UnitName}"
                                    Width="150"/>

                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity}"
                                    Width="120"/>

                <DataGridTextColumn Header="السعر"
                                    Binding="{Binding Price}"
                                    Width="120"/>

                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding Total}"
                                    Width="150"/>
                
                
                

            </DataGrid.Columns>

        </DataGrid>


        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">

            <TextBlock Text="الإجمالي الكلي : "
               FontSize="18"
               FontWeight="Bold"/>

            <TextBlock Text="{Binding GrandTotal}"
               FontSize="18"
               FontWeight="Bold"/>


            <StackPanel Orientation="Horizontal"
            Margin="0,10">

                <TextBlock Text="المدفوع : "
               Width="90"/>

                <TextBox Width="150"
             Text="{Binding PaidAmount}" />

            </StackPanel>

            <StackPanel Orientation="Horizontal"
            Margin="0,10">

                <TextBlock Text="المتبقي : "
               Width="90"/>

                <TextBlock Text="{Binding RemainingAmount}"
               FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

    </Grid>

</UserControl>